# Cấu hình biến môi trường chạy Docker Compose trên AWS Lightsail

# Điền IP Công cộng của máy ảo Lightsail của bạn vào đây (Ví dụ: 54.254.12.34)
# Nếu bạn đã có tên miền, hãy điền tên miền vào đây (Ví dụ: http://medflow.com)
PUBLIC_IP=http://localhost

# Cấu hình URLs bắt tay cho Frontend & Backend
FRONTEND_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:5001

# Đường dẫn Database MongoDB (Mặc định dùng container cục bộ, hoặc điền chuỗi kết nối MongoDB Atlas)
MONGO_URI=mongodb://mongodb:27017/hospital-management

# Các Key dịch vụ bảo mật (Thay thế bằng Key thực tế của bạn)
BETTER_AUTH_SECRET=MedFlowAuthSecret1307SuperSecureKey
GEMINI_KEY=your_gemini_api_key_here
UPLOADTHING_TOKEN=your_uploadthing_token_here

# Cấu hình gửi mail SMTP (Gmail)
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
